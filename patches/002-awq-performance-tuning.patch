+class AWQTritonMoEMethod(FusedMoEMethodBase):
+    """AWQ MoE for HIP/RDNA4 using the existing fused_moe_kernel_gptq_awq.
+
+    Repacks AWQ INT4 weights to GPTQ sequential format during loading, then
+    uses the standard Triton fused MoE kernel with use_int4_w4a16=True.
+    This gives full fused MoE performance with CUDA graph support.
+    """
+
+    AWQ_REVERSE_ORDER = [0, 4, 1, 5, 2, 6, 3, 7]
+
+    def __init__(self, quant_config: AWQConfig):
+        self.quant_config = quant_config
+        if self.quant_config.weight_bits != 4:
+            raise ValueError("AWQTritonMoEMethod only supports 4bit.")
+
+    def create_weights(
+        self,
+        layer: torch.nn.Module,
+        num_experts: int,
+        hidden_size: int,
+        intermediate_size_per_partition: int,
+        params_dtype: torch.dtype,
+        **extra_weight_attrs,
+    ):
+        from sglang.srt.layers.moe.fused_moe_triton import FusedMoeWeightScaleSupported
+
+        extra_weight_attrs.update({
+            "is_transposed": True,
+            "quant_method": FusedMoeWeightScaleSupported.GROUP.value,
+        })
+
+        pack_factor = self.quant_config.pack_factor  # 8 for 4-bit
+        group_size = self.quant_config.group_size
+
+        # AWQ format: qweight [E, K, N//8] int32, scales [E, K//G, N], qzeros [E, K//G, N//8] int32
+        w13_qweight = torch.nn.Parameter(
+            torch.empty(num_experts, hidden_size,
+                        2 * intermediate_size_per_partition // pack_factor,
+                        dtype=torch.int32),
+            requires_grad=False)
+        layer.register_parameter("w13_qweight", w13_qweight)
+        set_weight_attrs(w13_qweight, extra_weight_attrs)
+
+        w2_qweight = torch.nn.Parameter(
+            torch.empty(num_experts, intermediate_size_per_partition,
+                        hidden_size // pack_factor, dtype=torch.int32),
+            requires_grad=False)
+        layer.register_parameter("w2_qweight", w2_qweight)
+        set_weight_attrs(w2_qweight, extra_weight_attrs)
+
+        num_groups_w13 = hidden_size // group_size
+        num_groups_w2 = intermediate_size_per_partition // group_size
+
+        w13_scales = torch.nn.Parameter(
+            torch.empty(num_experts, num_groups_w13,
+                        intermediate_size_per_partition * 2, dtype=params_dtype),
+            requires_grad=False)
+        layer.register_parameter("w13_scales", w13_scales)
+        set_weight_attrs(w13_scales, extra_weight_attrs)
+
+        w2_scales = torch.nn.Parameter(
+            torch.empty(num_experts, num_groups_w2, hidden_size, dtype=params_dtype),
+            requires_grad=False)
+        layer.register_parameter("w2_scales", w2_scales)
+        set_weight_attrs(w2_scales, extra_weight_attrs)
+
+        w13_qzeros = torch.nn.Parameter(
+            torch.empty(num_experts, num_groups_w13,
+                        2 * intermediate_size_per_partition // pack_factor,
+                        dtype=torch.int32),
+            requires_grad=False)
+        layer.register_parameter("w13_qzeros", w13_qzeros)
+        set_weight_attrs(w13_qzeros, extra_weight_attrs)
+
+        w2_qzeros = torch.nn.Parameter(
+            torch.empty(num_experts, num_groups_w2,
+                        hidden_size // pack_factor, dtype=torch.int32),
+            requires_grad=False)
+        layer.register_parameter("w2_qzeros", w2_qzeros)
+        set_weight_attrs(w2_qzeros, extra_weight_attrs)
+
+    @staticmethod
+    def _awq_to_gptq_weight(qweight_awq: torch.Tensor) -> torch.Tensor:
+        """Repack AWQ [E, K, N//8] int32 → GPTQ [E, N, K//2] int8.
+
+        AWQ: 8 x 4-bit values per int32, interleaved order [0,4,1,5,2,6,3,7]
+        GPTQ: 2 x 4-bit values per int8, sequential order
+        """
+        E, K, N_packed = qweight_awq.shape
+        N = N_packed * 8
+
+        # Unpack AWQ int32 → [E, K, N] uint8 values
+        unpacked = torch.zeros(E, K, N, dtype=torch.uint8, device=qweight_awq.device)
+        for i, src_pos in enumerate(AWQTritonMoEMethod.AWQ_REVERSE_ORDER):
+            unpacked[:, :, i::8] = ((qweight_awq >> (src_pos * 4)) & 0xF).to(torch.uint8)
+
+        # Transpose [E, K, N] → [E, N, K]
+        unpacked = unpacked.permute(0, 2, 1).contiguous()
+
+        # Repack as int8: [E, N, K//2] with sequential packing
+        packed = (unpacked[:, :, 0::2] | (unpacked[:, :, 1::2] << 4)).to(torch.int8)
+        return packed.contiguous()
+
+    @staticmethod
+    def _awq_to_gptq_zeros(qzeros_awq: torch.Tensor) -> torch.Tensor:
+        """Repack AWQ zeros [E, G, N//8] int32 → GPTQ [E, G, N//2] int8."""
+        E, G, N_packed = qzeros_awq.shape
+        N = N_packed * 8
+
+        unpacked = torch.zeros(E, G, N, dtype=torch.uint8, device=qzeros_awq.device)
+        for i, src_pos in enumerate(AWQTritonMoEMethod.AWQ_REVERSE_ORDER):
+            unpacked[:, :, i::8] = ((qzeros_awq >> (src_pos * 4)) & 0xF).to(torch.uint8)
+
+        packed = (unpacked[:, :, 0::2] | (unpacked[:, :, 1::2] << 4)).to(torch.int8)
+        return packed.contiguous()
+
+    def process_weights_after_loading(self, layer: torch.nn.Module) -> None:
+        # Keep weights in native AWQ format for per-expert dispatch.
+        # TODO: Repack to GPTQ format for fused_moe_kernel_gptq_awq (needs
+        # debugging of the AWQ→GPTQ repack to fix garbage output).
+        pass
+
+    def create_moe_runner(
+        self, layer: torch.nn.Module, moe_runner_config: MoeRunnerConfig
+    ):
+        self.moe_runner_config = moe_runner_config
+
+    def apply(
+        self,
+        layer: torch.nn.Module,
+        dispatch_output,
+    ):
+        from sglang.srt.layers.moe.token_dispatcher import StandardCombineInput
+
+        x = dispatch_output.hidden_states  # [M, K]
+        topk_weights, topk_ids, _ = dispatch_output.topk_output
+
+        M, K = x.shape
+        top_k = topk_ids.shape[1]
+        num_experts = layer.w13_qweight.shape[0]
+        intermediate = layer.w2_qweight.shape[1]
+
+        output = torch.zeros_like(x)
+
+        for expert_id in range(num_experts):
+            mask = (topk_ids == expert_id)
+            if not mask.any():
+                continue
+
+            token_indices, slot_indices = mask.nonzero(as_tuple=True)
+            weights = topk_weights[token_indices, slot_indices]
+            expert_input = x[token_indices]
+
+            # GEMM1: gate+up via AWQ
+            gate_up = awq_gemm_triton(
+                expert_input,
+                layer.w13_qweight[expert_id],
+                layer.w13_scales[expert_id],
+                layer.w13_qzeros[expert_id],
+                split_k_iters=8, block_size_m=16,
+                block_size_n=64, block_size_k=64,
+            )
+
+            # SiLU activation
+            gate = gate_up[:, :intermediate]
+            up = gate_up[:, intermediate:]
+            activated = torch.nn.functional.silu(gate) * up
+
+            # GEMM2: down via AWQ
+            expert_output = awq_gemm_triton(
+                activated,
+                layer.w2_qweight[expert_id],
+                layer.w2_scales[expert_id],
+                layer.w2_qzeros[expert_id],
+                split_k_iters=8, block_size_m=16,
+                block_size_n=64, block_size_k=64,
+            )
+
+            expert_output = expert_output * weights.unsqueeze(-1)
+            output.index_add_(0, token_indices, expert_output.to(output.dtype))
+
+        return StandardCombineInput(hidden_states=output)
+
+
 class AWQMoEAscendMethod(AWQMoEMethod):
     def __init__(self, quant_config: AWQConfig):
         self.quant_config = quant_config
