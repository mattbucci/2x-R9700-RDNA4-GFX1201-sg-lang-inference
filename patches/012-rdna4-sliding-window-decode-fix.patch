+@triton.jit
+def _kv_indices_kernel(
+    req_to_token_ptr, req_pool_indices_ptr, page_kernel_lens_ptr,
+    kv_indptr, kv_start_idx, kv_indices_ptr,
+    req_to_token_ptr_stride: tl.constexpr,
+    HAS_START_IDX: tl.constexpr,
+):
+    """Copy token indices from req_to_token pool into kv_indices.
+    Split from create_flashinfer_kv_indices_triton to avoid the `if ptr:`
+    null-check pattern that crashes on RDNA4 (gfx1201)."""
+    BLOCK_SIZE: tl.constexpr = 256  # Reduced from 512 for RDNA4 register pressure
+    pid = tl.program_id(axis=0)
+
+    req_pool_index = tl.load(req_pool_indices_ptr + pid)
+    kv_indices_offset = tl.load(kv_indptr + pid)
+
+    kv_start = tl.zeros([], dtype=tl.int32)
+    if HAS_START_IDX:
+        kv_start = tl.load(kv_start_idx + pid).to(tl.int32)
+    kv_end = kv_start + tl.load(page_kernel_lens_ptr + pid).to(tl.int32)
+
+    num_loop = tl.cdiv(kv_end - kv_start, BLOCK_SIZE)
+    for i in range(num_loop):
+        offset = tl.arange(0, BLOCK_SIZE).to(tl.int64) + i * BLOCK_SIZE
+        mask = offset < kv_end - kv_start
+        data = tl.load(
+            req_to_token_ptr
+            + req_pool_index.to(tl.int64) * req_to_token_ptr_stride
+            + kv_start.to(tl.int64)
+            + offset,
+            mask=mask,
+        )
+        tl.store(kv_indices_ptr + kv_indices_offset.to(tl.int64) + offset, data, mask=mask)
+
+
+def _create_kv_indices(req_to_token, req_pool_indices, page_kernel_lens,
+                       kv_indptr, kv_start_idx, kv_indices):
+    """RDNA4-safe replacement for create_flashinfer_kv_indices_triton.
+    Uses constexpr HAS_START_IDX instead of runtime null-pointer check."""
+    bs = req_pool_indices.shape[0]
+    if bs == 0:
+        return
+    _kv_indices_kernel[(bs,)](
+        req_to_token, req_pool_indices, page_kernel_lens,
+        kv_indptr,
+        kv_start_idx if kv_start_idx is not None else req_pool_indices,  # dummy ptr
+        kv_indices,
+        req_to_token.stride(0),
+        HAS_START_IDX=(kv_start_idx is not None),
+    )
+
