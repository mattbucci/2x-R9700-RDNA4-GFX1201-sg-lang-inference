+        if _is_hip:
+            M = reshaped_x.shape[0]
+            if M == 1:
+                # Single-token decode: maximize K-parallelism
+                split_k, bm, bn, bk = 16, 16, 64, 64
+            elif M <= 8:
+                # Small batch decode
+                split_k, bm, bn, bk = 8, 16, 64, 64
+            elif M <= 32:
+                # Medium batch (default, previously tuned)
+                split_k, bm, bn, bk = 8, 32, 64, 64
+            else:
+                # Large batch / prefill: maximize throughput
+                split_k, bm, bn, bk = 2, 64, 128, 64
+            out = awq_gemm_triton(
